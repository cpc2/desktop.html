# Normalize line endings: LF in the repo, native on checkout for scripts.
* text=auto

*.cs text
*.csproj text
*.sln text
*.js text
*.css text
*.html text
*.json text
*.md text
*.yml text
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.dll binary
*.exe binary
*.wasm binary
*.woff binary
*.woff2 binary
